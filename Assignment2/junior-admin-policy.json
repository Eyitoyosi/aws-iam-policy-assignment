{
  "Version":"2012-10-17",
  "Statement":[
    {
      "Effect":"Allow",
      "Action":[
        "iam:CreateUser",
        "iam:GetUser",
        "iam:ListUsers",
        "iam:UpdateLoginProfile"
      ],
      "Resource":"*"
    },
    {
      "Effect":"Deny",
      "Action":[
        "iam:DeleteUser",
        "iam:DeletePolicy",
        "iam:CreateAccessKey"
      ],
      "Resource":"*"
    }
  ]
}
